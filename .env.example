# Server
PORT=3000
NODE_ENV=development

# Admin panel credentials (CHANGE in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# PostgreSQL connection. Leave empty to use local store.json fallback.
# Railway provides this automatically when you attach a Postgres plugin.
DATABASE_URL=

# Optional Gemini API key (currently unused at runtime)
GEMINI_API_KEY=
